## 🧠 Container Template
```svelte
<script lang="ts">
  import { $effect, $derived } from 'svelte';
  import { someStore } from '../services.svelte';
  import SomeComponent from '../components/some-component.svelte';

  const data = $derived(someStore);
  $effect(() => console.log('store changed', data));
</script>

<SomeComponent prop1={data?.title} />
```

