## 🎨 Component Template
```svelte
<script lang="ts">
  import { cn } from '$lib/shared/utils/cn';

  interface ComponentProps {
    prop1: string;
    className?: string;
    children?: import('svelte').Snippet;
  }

  let { prop1, className, children }: ComponentProps = $props();

  const count = $state(0);
  $effect(() => console.log('count changed', count));

  function onclick() {
    count++;
  }
</script>

<div class={cn('component-name', className)}>
  <button class="btn" {onclick}>
    Clicked {count}
  </button>
  {#if children}
    {@render children()}
  {/if}
</div>

<style>
  .btn {
    @apply px-3 py-1 bg-blue-500 text-white rounded;
  }
</style>
```

