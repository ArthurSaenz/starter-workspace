## 🧱 Utility Example (`cn`)
```ts
export function cn(...parts: Array<string | false | null | undefined>) {
  return parts.filter(Boolean).join(' ');
}
```
Usage:
```svelte
<div class={cn('btn', primary && 'btn--primary', className)} />
```

