## 🧰 Services & Stores
```ts
import { $state, $derived } from 'svelte';

export interface Item { 
  id: string; 
  title: string; 
}

const _items = $state<Item[]>([]);
export const items = $derived(_items);

export async function fetchItems(api = fetch) {
  const res = await api('/api/items');
  _items.length = 0;
  _items.push(...await res.json());
}

export function reset() {
  _items.length = 0;
}
```

