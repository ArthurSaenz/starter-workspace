## 🧩 Composition Patterns

### Props with `$props()`
**Always define TypeScript interfaces for props:**
```svelte
<script lang="ts">
  interface ButtonProps {
    label: string;
    className?: string;
    onclick?: (event: MouseEvent) => void;
  }

  let { label, className, onclick }: ButtonProps = $props();
</script>

<button class={className} {onclick}>{label}</button>
```

**Props are always required unless marked with `?` or given a default value:**
```svelte
<script lang="ts">
  interface Props {
    required: string;
    optional?: string;
    withDefault: string = 'default';
  }
  let { required, optional, withDefault }: Props = $props();
</script>
```

**Prop renaming** (e.g., for reserved keywords):
```svelte
<script lang="ts">
  let { class: className, ...rest } = $props();
</script>

<button class={className} {...rest}>click me</button>
```

**Spreading all props**:
```svelte
<script lang="ts">
  let props = $props();
</script>

<button {...props}>click me</button>
```

### Snippets (replaces slots)
**Default content**:
```svelte
<!-- Parent -->
<Button>
  Click me
</Button>

<!-- Button.svelte -->
<script lang="ts">
  interface ButtonProps {
    children?: import('svelte').Snippet;
  }
  let { children }: ButtonProps = $props();
</script>

<button>
  {#if children}
    {@render children()}
  {/if}
</button>
```

**Multiple content placeholders**:
```svelte
<!-- Parent -->
<Layout>
  {#snippet header()}
    <h1>Title</h1>
  {/snippet}
  
  {#snippet main()}
    <p>Content</p>
  {/snippet}
  
  {#snippet footer()}
    <p>Footer</p>
  {/snippet}
</Layout>

<!-- Layout.svelte -->
<script lang="ts">
  interface LayoutProps {
    header?: import('svelte').Snippet;
    main?: import('svelte').Snippet;
    footer?: import('svelte').Snippet;
  }
  let { header, main, footer }: LayoutProps = $props();
</script>

<header>
  {#if header}
    {@render header()}
  {/if}
</header>
<main>
  {#if main}
    {@render main()}
  {/if}
</main>
<footer>
  {#if footer}
    {@render footer()}
  {/if}
</footer>
```

**Passing data to snippets**:
```svelte
<!-- Parent -->
<List items={['one', 'two', 'three']}>
  {#snippet item(text)}
    <span>{text}</span>
  {/snippet}
  
  {#snippet empty()}
    <span>No items yet</span>
  {/snippet}
</List>

<!-- List.svelte -->
<script lang="ts">
  interface ListProps {
    items: string[];
    item?: import('svelte').Snippet<[string]>;
    empty?: import('svelte').Snippet;
  }
  let { items, item, empty }: ListProps = $props();
</script>

{#if items.length}
  <ul>
    {#each items as entry}
      <li>
        {#if item}
          {@render item(entry)}
        {/if}
      </li>
    {/each}
  </ul>
{:else}
  {#if empty}
    {@render empty()}
  {/if}
{/if}
```

### Component Events (Callback Props)
**Never use `createEventDispatcher`** — use callback props instead:
```svelte
<!-- Parent -->
<Pump
  inflate={(power) => {
    size += power;
    if (size > 75) burst = true;
  }}
  deflate={(power) => {
    if (size > 0) size -= power;
  }}
/>

<!-- Pump.svelte -->
<script lang="ts">
  interface PumpProps {
    inflate?: (power: number) => void;
    deflate?: (power: number) => void;
  }
  let { inflate, deflate }: PumpProps = $props();
  let power = $state(5);

  function handleInflate() {
    inflate?.(power);
  }

  function handleDeflate() {
    deflate?.(power);
  }
</script>

<button onclick={handleInflate}>inflate</button>
<button onclick={handleDeflate}>deflate</button>
```

### Event Handlers
**Use `onclick`, `onkeydown`, etc.** (no colon). Prefer shorthand syntax `{onclick}` when using named functions:
```svelte
<script lang="ts">
  const count = $state(0);
  
  function onclick() {
    count++;
  }
</script>

<button {onclick}>clicks: {count}</button>
```

**For inline handlers, use full syntax:**
```svelte
<button onclick={() => count++}>clicks: {count}</button>
```

**Multiple event handlers:**
```svelte
<script lang="ts">
  function onclick(e: MouseEvent) {
    one(e);
    two(e);
  }
</script>

<button {onclick}>
  ...
</button>
```

**When spreading props, local handlers go after:**
```svelte
<script lang="ts">
  function onclick(e: MouseEvent) {
    doStuff(e);
    props.onclick?.(e);
  }
</script>

<button
  {...props}
  {onclick}
>
  ...
</button>
```

### Event Modifiers
Event modifiers (`|once|preventDefault`) don't work with modern event handlers. Use wrapper functions:
```svelte
<script lang="ts">
  function once(fn: ((event: Event) => void) | null) {
    return function (event: Event) {
      if (fn) fn.call(this, event);
      fn = null;
    };
  }

  function preventDefault(fn: ((event: Event) => void) | undefined) {
    return function (event: Event) {
      event.preventDefault();
      fn?.call(this, event);
    };
  }
</script>

<button onclick={once(preventDefault(handler))}>...</button>
```

**Capture modifier**:
```svelte
<button onclickcapture={...}>...</button>
```

### Dynamic Component
```svelte
<Card Content={RichCard} />
<svelte:component this={Content} />
```
> Avoid component creation inside `$effect` or reactive expressions.

