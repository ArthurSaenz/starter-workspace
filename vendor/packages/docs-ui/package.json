{
  "name": "@wl/docs-ui",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Self-contained fumadocs documentation app (white-label, source package) for white-label repos",
  "engines": {
    "node": ">=24.x",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "clean-cache": "rm -rf node_modules/.cache node_modules/.vite .turbo .source .tanstack",
    "clean-artifacts": "rm -rf dist .output .nitro",
    "prettier-fix": "pnpm exec prettier **/* --write --no-error-on-unmatched-pattern --log-level silent --ignore-path ../../../.prettierignore",
    "prettier-check": "pnpm exec prettier **/* --check --no-error-on-unmatched-pattern --log-level silent --ignore-path ../../../.prettierignore",
    "eslint-check": "eslint --cache --quiet --report-unused-disable-directives ./src",
    "eslint-fix": "eslint --cache --quiet --report-unused-disable-directives ./src --fix",
    "ts-check": "fumadocs-mdx && tsc --noEmit",
    "test": "vitest run --reporter=minimal",
    "test-watch": "vitest --watch --silent passed-only",
    "test-ui": "vitest --ui --silent passed-only",
    "test-report": "vitest run --coverage --silent passed-only",
    "qa": "pnpm run prettier-check && pnpm run eslint-check && pnpm run ts-check && pnpm run test && echo ✅ Success",
    "fix": "pnpm run prettier-fix && pnpm run eslint-fix && pnpm run qa"
  },
  "dependencies": {
    "@orama/orama": "^3.1.6",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/start-static-server-functions": "^1.167.17",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.11",
    "fumadocs-ui": "16.9.3",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/mdx": "2.0.14",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@wl/eslint-config": "workspace:*",
    "@wl/vitest-config": "workspace:*",
    "nitro": "3.0.260603-beta",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
